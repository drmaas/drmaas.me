---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Resume — Dan Maas" description="Dan Maas — Principal Engineer. Resume and professional experience." activeLink="">
  <div class="min-h-screen bg-base-200">
    <!-- Header banner -->
    <div class="bg-base-300 border-b border-base-content/10">
      <div class="px-6 py-8 md:px-12">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <h1 class="text-4xl font-bold">Dan Maas</h1>
            <p class="text-lg text-base-content/70 mt-1">Principal Engineer — Building scalable services and systems</p>
          </div>
          <div class="text-sm text-base-content/60 space-y-1 text-left md:text-right">
            <p>drmaas@duck.com</p>
            <p>(612) 741-6581</p>
            <p>github.com/drmaas</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div class="px-6 md:px-12 py-8">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Left column: Skills, Education, Certifications -->
        <aside class="lg:w-80 shrink-0">
          <div class="space-y-6">
            <section class="bg-base-100 rounded-box p-6 shadow-sm">
              <h2 class="text-lg font-bold uppercase tracking-wider text-base-content/60 mb-4">Skills</h2>
              <div class="flex flex-wrap gap-2">
                {["AWS", "Terraform", "Nomad", "Docker", "Linux", "Microservices", "Domain Driven Design", "Data Modeling", "Java", "Kotlin", "Python", "Go", "TypeScript", "Node.js", "Kafka", "SQL", "Cassandra", "MongoDB", "OAuth / OIDC"].map(s => (
                  <span class="badge badge-outline badge-md">{s}</span>
                ))}
              </div>
            </section>

            <section class="bg-base-100 rounded-box p-6 shadow-sm">
              <h2 class="text-lg font-bold uppercase tracking-wider text-base-content/60 mb-4">Education</h2>
              <div class="space-y-4">
                <div>
                  <p class="font-semibold">Master of Software Engineering</p>
                  <p class="text-sm text-base-content/70">University of Minnesota, 2011–2013</p>
                  <p class="text-sm text-base-content/70">GPA: 3.9</p>
                </div>
                <div>
                  <p class="font-semibold">B.S. Computer Engineering & Computer Science</p>
                  <p class="text-sm text-base-content/70">University of Wisconsin, 1999–2004</p>
                  <p class="text-sm text-base-content/70">GPA: 3.5</p>
                </div>
              </div>
            </section>

            <section class="bg-base-100 rounded-box p-6 shadow-sm">
              <h2 class="text-lg font-bold uppercase tracking-wider text-base-content/60 mb-4">Certifications</h2>
              <p class="font-semibold">AWS Certified Solutions Architect – Associate</p>
              <p class="text-sm text-base-content/70">Issued Sep 2023 – Expires Sep 2026</p>
            </section>
          </div>
        </aside>

        <!-- Right column: Work History -->
        <div class="flex-1 min-w-0">
          <section class="bg-base-100 rounded-box p-6 shadow-sm">
            <h2 class="text-lg font-bold uppercase tracking-wider text-base-content/60 mb-6">Experience</h2>

            <div class="space-y-8">
              <div>
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
                  <h3 class="text-xl font-bold">Principal Engineer</h3>
                  <span class="text-sm text-base-content/50 whitespace-nowrap">2023 – Present</span>
                </div>
                <p class="text-base font-medium text-base-content/80 mb-2">Salesforce</p>
                <ul class="list-disc pl-5 space-y-1.5 text-base-content/80">
                  <li>Designed authentication and authorization servers using OpenID Connect (OIDC)</li>
                  <li>Designed lead generation apps to capture marketing signals across Salesforce sites</li>
                  <li>Assisted scrum teams with microservices architectures</li>
                </ul>
              </div>

              <div>
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
                  <h3 class="text-xl font-bold">Principal Engineer</h3>
                  <span class="text-sm text-base-content/50 whitespace-nowrap">2021 – 2023</span>
                </div>
                <p class="text-base font-medium text-base-content/80 mb-2">Target</p>
                <ul class="list-disc pl-5 space-y-1.5 text-base-content/80">
                  <li>Created architecture for B2B ecommerce giftcard site (targetcorporategiftcards.com)</li>
                  <li>Defined a new application architecture for Redcard applications</li>
                  <li>Led design for Redcard account management</li>
                </ul>
              </div>

              <div>
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
                  <h3 class="text-xl font-bold">Principal Engineer</h3>
                  <span class="text-sm text-base-content/50 whitespace-nowrap">2017 – 2021</span>
                </div>
                <p class="text-base font-medium text-base-content/80 mb-2">Target</p>
                <ul class="list-disc pl-5 space-y-1.5 text-base-content/80">
                  <li>Designed platform and guest-facing omnichannel ecommerce APIs for stores and web</li>
                  <li>Designed cart and checkout microservices</li>
                  <li>Led scrum team meetings and design reviews</li>
                </ul>
              </div>

              <div>
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
                  <h3 class="text-xl font-bold">Lead Engineer</h3>
                  <span class="text-sm text-base-content/50 whitespace-nowrap">2015 – 2017</span>
                </div>
                <p class="text-base font-medium text-base-content/80 mb-2">Target</p>
                <ul class="list-disc pl-5 space-y-1.5 text-base-content/80">
                  <li>Built microservices for inventory availability</li>
                  <li>Started goalert.me project and defined initial design</li>
                  <li>Contributed code to Spinnaker project</li>
                </ul>
              </div>
            </div>
          </section>

          <section class="bg-base-100 rounded-box p-6 shadow-sm mt-6">
            <h2 class="text-lg font-bold uppercase tracking-wider text-base-content/60 mb-4">Miscellaneous</h2>
            <p class="font-semibold mb-2">Hobbies</p>
            <p class="text-base-content/80">Reading, Coding, Hiking, Biking, Swimming, Yoga</p>
          </section>

          <footer class="text-center py-8">
            <div class="inline-flex items-center gap-2 bg-base-300/50 border border-base-content/10 rounded-full px-5 py-2.5">
              <svg class="w-5 h-5 text-base-content/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
              <span class="text-sm text-base-content/60">Visitor # <span id="visitor-counter" class="font-mono font-bold tabular-nums text-base-content">—</span></span>
            </div>
          </footer>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  let isProcessing = false;

  async function fetchCounter() {
    const counterEl = document.getElementById("visitor-counter");
    if (!counterEl || isProcessing) return;

    isProcessing = true;
    counterEl.className = "font-mono font-bold tabular-nums transition-all duration-500 text-base-content";

    try {
      const response = await fetch("https://api.drmaas.me/resume/increment", {
        method: "POST",
        headers: { Accept: "application/json", "Content-Type": "application/json" },
        body: JSON.stringify({}),
      });

      const data = await response.json();
      const target = data.counter;

      let current = 0;
      const step = Math.max(1, Math.floor(target / 25));
      const tick = () => {
        current = Math.min(current + step, target);
        counterEl.textContent = current.toLocaleString();
        if (current < target) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    } catch {
      counterEl.textContent = "—";
      counterEl.className = "font-mono tabular-nums text-base-content/20";
    } finally {
      isProcessing = false;
    }
  }

  // astro:page-load fires after every navigation (including the first page load)
  // when ClientRouter is active — this is the correct hook to use.
  document.addEventListener("astro:page-load", fetchCounter);
</script>